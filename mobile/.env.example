# Backend base URL (ALB). Required only when EXPO_PUBLIC_USE_MOCKS=false.
# Do not commit .env with real values.
EXPO_PUBLIC_API_BASE_URL=https://your-real-api.example.com

# Set to 'true' to enable the local mock data layer (no network calls).
# This is the default for local development.
EXPO_PUBLIC_USE_MOCKS=true

# Set to 'true' to enable structured API request/response logging.
# Logs endpoint, method, status, duration_ms, platform, env, app_version.
# Never logs Authorization headers, passwords, tokens, or request/response bodies.
# Default: off.
EXPO_PUBLIC_API_LOGGING=false

# Mapbox public access token (LiveMapPage in dev/standalone builds). Expo Go uses the fallback UI without native Mapbox.
# Create at https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional: iOS/Android native SDK download token for prebuild (see docs/TESTING.md)
# RNMAPBOX_MAPS_DOWNLOAD_TOKEN=
