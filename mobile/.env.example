# Expo Go cannot reach your dev machine (slow QR / "check connectivity")?
# - Same Wi‑Fi but still stuck: try `npm run start:tunnel` (works through most firewalls / phone hotspots).
# - Same Wi‑Fi only: `npm run start:lan` and ensure Mac firewall allows Node for private networks.
# - Turn off VPN on Mac + iPhone; on hotspot, "client isolation" often breaks LAN mode—use tunnel.

# Backend base URL — must be reachable from your phone (HTTPS, valid cert).
# Placeholder hostnames will fail in Expo Go with "network request failed".
EXPO_PUBLIC_API_BASE_URL=https://api.cyclelink.example.com

# Mapbox public access token (LiveMapPage). Create at https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional: iOS/Android native SDK download token for prebuild (see docs/TESTING.md)
# RNMAPBOX_MAPS_DOWNLOAD_TOKEN=

# 'true' = login/register use local mock DB + no HTTP (best for Expo Go without a deployed API).
# 'false' = real API at EXPO_PUBLIC_API_BASE_URL (must exist and allow your app).
EXPO_PUBLIC_USE_MOCKS=true

# Set to 'true' to enable structured API request/response logging.
# Logs endpoint, method, status, duration_ms, platform, env, app_version.
# Never logs Authorization headers, passwords, tokens, or request/response bodies.
# Default: off.
EXPO_PUBLIC_API_LOGGING=false
