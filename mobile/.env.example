# Backend base URL (ALB). Do not commit .env with real values.
EXPO_PUBLIC_API_BASE_URL=https://api.cyclelink.example.com

# Set to 'true' to enable the local mock data layer (no network calls).
# Keep this enabled for local development unless you are testing a real backend.
EXPO_PUBLIC_USE_MOCKS=true

# Set to 'true' to enable structured API request/response logging.
# Logs endpoint, method, status, duration_ms, platform, env, app_version.
# Never logs Authorization headers, passwords, tokens, or request/response bodies.
# Default: off.
EXPO_PUBLIC_API_LOGGING=false
