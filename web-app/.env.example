# Backend base URL. Do not commit .env with real values.
VITE_API_BASE_URL=https://api.cyclelink.example.com

# Set to 'true' to enable the local mock data layer (no network calls).
VITE_USE_MOCKS=false

# Set to 'true' to enable structured API request/response logging.
# Logs endpoint, method, status, duration_ms, platform, env.
# Never logs Authorization headers, passwords, tokens, or request/response bodies.
# Default: off.
VITE_API_LOGGING=false
